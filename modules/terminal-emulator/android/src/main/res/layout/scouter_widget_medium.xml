<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/scouter_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="12dp"
  android:background="@drawable/scouter_widget_bg">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
      android:id="@+id/scouter_status_dot"
      android:layout_width="12dp"
      android:layout_height="12dp"
      android:src="@drawable/scouter_status_dot"
      android:contentDescription="@string/scouter_status_dot" />

    <TextView
      android:id="@+id/scouter_title"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="8dp"
      android:layout_weight="1"
      android:ellipsize="middle"
      android:singleLine="true"
      android:text="Scouter"
      android:textColor="#E5E7EB"
      android:textSize="14sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/scouter_source_badge"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:background="@drawable/scouter_badge_bg"
      android:paddingStart="6dp"
      android:paddingEnd="6dp"
      android:paddingTop="2dp"
      android:paddingBottom="2dp"
      android:text="SH"
      android:textColor="#111827"
      android:textSize="10sp"
      android:textStyle="bold" />
  </LinearLayout>

  <TextView
    android:id="@+id/scouter_detail"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:ellipsize="middle"
    android:singleLine="true"
    android:text="No agent session yet"
    android:textColor="#D1D5DB"
    android:textSize="13sp" />

  <TextView
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="7dp"
    android:background="#263241"
    android:text="" />

  <TextView
    android:id="@+id/scouter_metrics"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:ellipsize="end"
    android:singleLine="true"
    android:text="Open Shelly to start"
    android:textColor="#9CA3AF"
    android:textSize="12sp" />
</LinearLayout>
