<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/scouter_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:padding="2dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="top"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="6dp"
    android:paddingEnd="10dp"
    android:paddingBottom="4dp"
    android:background="@drawable/scouter_widget_bg">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <ImageView
        android:id="@+id/scouter_codex_dot"
        android:layout_width="11dp"
        android:layout_height="11dp"
        android:src="@drawable/scouter_status_dot"
        android:contentDescription="@string/scouter_status_dot" />

      <TextView
        android:id="@+id/scouter_codex_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="7dp"
        android:layout_weight="1"
        android:ellipsize="middle"
        android:singleLine="true"
        android:text="CODEX"
        android:textColor="#F8FFFF"
        android:textSize="14sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />

      <TextView
        android:id="@+id/scouter_codex_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/scouter_badge_bg"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="CX"
        android:textColor="#001200"
        android:textSize="10sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />

      <TextView
        android:id="@+id/scouter_codex_ask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:background="@drawable/scouter_badge_bg"
        android:contentDescription="@string/scouter_ask_agent_chat"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="@string/scouter_ask_agent_chat_short"
        android:textColor="#001200"
        android:textSize="10sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />

      <TextView
        android:id="@+id/scouter_codex_allow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:background="@drawable/scouter_badge_bg"
        android:contentDescription="@string/scouter_widget_approval_allow"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="@string/scouter_widget_approval_allow_short"
        android:textColor="#001200"
        android:textSize="10sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false"
        android:visibility="gone" />

      <TextView
        android:id="@+id/scouter_codex_deny"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:background="@drawable/scouter_badge_bg"
        android:contentDescription="@string/scouter_widget_approval_deny"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="@string/scouter_widget_approval_deny_short"
        android:textColor="#001200"
        android:textSize="10sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false"
        android:visibility="gone" />
    </LinearLayout>

    <TextView
      android:id="@+id/scouter_codex_detail"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="3dp"
      android:ellipsize="end"
      android:singleLine="true"
      android:text="No Codex session"
      android:textColor="#63FF8F"
      android:textSize="11sp"
      android:typeface="monospace"
      android:textStyle="bold"
      android:includeFontPadding="false" />

    <TextView
      android:id="@+id/scouter_codex_metrics"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="2dp"
      android:ellipsize="end"
      android:maxLines="3"
      android:text="Waiting for ~/.codex/sessions"
      android:textColor="#B8FFD0"
      android:textSize="9sp"
      android:typeface="monospace"
      android:textStyle="bold"
      android:lineSpacingExtra="0dp"
      android:includeFontPadding="false" />

    <TextView
      android:id="@+id/scouter_codex_conversation"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="3dp"
      android:ellipsize="end"
      android:maxLines="2"
      android:text=""
      android:textColor="#D8FFE8"
      android:textSize="10sp"
      android:typeface="monospace"
      android:textStyle="bold"
      android:lineSpacingExtra="0dp"
      android:includeFontPadding="false"
      android:visibility="gone" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:layout_marginTop="3dp"
      android:layout_marginBottom="3dp"
      android:background="#33338F33"
      android:text="" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <ImageView
        android:id="@+id/scouter_local_dot"
        android:layout_width="11dp"
        android:layout_height="11dp"
        android:src="@drawable/scouter_status_dot"
        android:contentDescription="@string/scouter_status_dot" />

      <TextView
        android:id="@+id/scouter_local_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="7dp"
        android:layout_weight="1"
        android:ellipsize="middle"
        android:singleLine="true"
        android:text="LOCAL LLM"
        android:textColor="#F8FFFF"
        android:textSize="14sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />

      <TextView
        android:id="@+id/scouter_local_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/scouter_badge_bg"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="LL"
        android:textColor="#001200"
        android:textSize="10sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />
    </LinearLayout>

    <TextView
      android:id="@+id/scouter_local_detail"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="3dp"
      android:ellipsize="end"
      android:singleLine="true"
      android:text="No local endpoint"
      android:textColor="#63FF8F"
      android:textSize="11sp"
      android:typeface="monospace"
      android:textStyle="bold"
      android:includeFontPadding="false" />

    <TextView
      android:id="@+id/scouter_local_metrics"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="2dp"
      android:ellipsize="end"
      android:maxLines="2"
      android:text="Probe 8080 / 11434"
      android:textColor="#B8FFD0"
      android:textSize="9sp"
      android:typeface="monospace"
      android:textStyle="bold"
      android:lineSpacingExtra="0dp"
      android:includeFontPadding="false" />

    <TextView
      android:id="@+id/scouter_footer"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="1dp"
      android:ellipsize="end"
      android:singleLine="true"
      android:text="updated --:--:--"
      android:textColor="#78EFFF"
      android:textSize="9sp"
      android:typeface="monospace"
      android:textStyle="bold"
      android:includeFontPadding="false" />
  </LinearLayout>
</FrameLayout>
