<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/scouter_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:padding="2dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="7dp"
    android:paddingEnd="10dp"
    android:paddingBottom="5dp"
    android:background="@drawable/scouter_widget_bg">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <ImageView
        android:id="@+id/scouter_codex_dot"
        android:layout_width="11dp"
        android:layout_height="11dp"
        android:src="@drawable/scouter_status_dot"
        android:contentDescription="@string/scouter_status_dot" />

      <TextView
        android:id="@+id/scouter_codex_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="7dp"
        android:layout_weight="1"
        android:ellipsize="middle"
        android:singleLine="true"
        android:text="CODEX"
        android:textColor="#F4FFF4"
        android:textSize="14sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />

      <TextView
        android:id="@+id/scouter_codex_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/scouter_badge_bg"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="CX"
        android:textColor="#001200"
        android:textSize="10sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />
    </LinearLayout>

    <TextView
      android:id="@+id/scouter_codex_detail"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="3dp"
      android:ellipsize="end"
      android:singleLine="true"
      android:text="No Codex session"
      android:textColor="#7DDB7D"
      android:textSize="11sp"
      android:typeface="monospace"
      android:textStyle="bold"
      android:includeFontPadding="false" />

    <TextView
      android:id="@+id/scouter_codex_metrics"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="2dp"
      android:ellipsize="end"
      android:maxLines="2"
      android:text="Waiting for ~/.codex/sessions"
      android:textColor="#9BC49B"
      android:textSize="9sp"
      android:typeface="monospace"
      android:textStyle="bold"
      android:lineSpacingExtra="0dp"
      android:includeFontPadding="false" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:layout_marginTop="4dp"
      android:layout_marginBottom="4dp"
      android:background="#33338F33"
      android:text="" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <ImageView
        android:id="@+id/scouter_local_dot"
        android:layout_width="11dp"
        android:layout_height="11dp"
        android:src="@drawable/scouter_status_dot"
        android:contentDescription="@string/scouter_status_dot" />

      <TextView
        android:id="@+id/scouter_local_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="7dp"
        android:layout_weight="1"
        android:ellipsize="middle"
        android:singleLine="true"
        android:text="LOCAL LLM"
        android:textColor="#F4FFF4"
        android:textSize="14sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />

      <TextView
        android:id="@+id/scouter_local_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/scouter_badge_bg"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="LL"
        android:textColor="#001200"
        android:textSize="10sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />
    </LinearLayout>

    <TextView
      android:id="@+id/scouter_local_detail"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="3dp"
      android:ellipsize="end"
      android:singleLine="true"
      android:text="No local endpoint"
      android:textColor="#7DDB7D"
      android:textSize="11sp"
      android:typeface="monospace"
      android:textStyle="bold"
      android:includeFontPadding="false" />

    <TextView
      android:id="@+id/scouter_local_metrics"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="2dp"
      android:ellipsize="end"
      android:maxLines="2"
      android:text="Probe 8080 / 11434"
      android:textColor="#9BC49B"
      android:textSize="9sp"
      android:typeface="monospace"
      android:textStyle="bold"
      android:lineSpacingExtra="0dp"
      android:includeFontPadding="false" />

    <TextView
      android:id="@+id/scouter_footer"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="2dp"
      android:ellipsize="end"
      android:singleLine="true"
      android:text="updated --:--:--"
      android:textColor="#7A967A"
      android:textSize="9sp"
      android:typeface="monospace"
      android:textStyle="bold"
      android:includeFontPadding="false" />
  </LinearLayout>
</FrameLayout>
