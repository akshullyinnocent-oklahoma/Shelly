<?xml version="1.0" encoding="utf-8"?>
<!-- Even-G2 style: soft dark "smoke" that is darkest behind the content and
     fades to near-transparent at the edges, plus a thin deep-green outline.
     No solid panel — the widget floats over the wallpaper as a HUD. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
  android:shape="rectangle">
  <corners android:radius="18dp" />
  <gradient
    android:type="radial"
    android:gradientRadius="82%p"
    android:centerX="0.5"
    android:centerY="0.6"
    android:startColor="#A6000000"
    android:endColor="#0D000000" />
  <stroke
    android:width="1dp"
    android:color="#CC12B53E" />
</shape>
